#!/usr/bin/with-contenv bash
# shellcheck shell=bash

set -euo pipefail

mkdir -p "${KOMGA_CONFIGDIR:-/config}" /data

enabled="${RCLONE_MOUNT_ENABLED,,}"
if [[ "${enabled}" == "1" || "${enabled}" == "true" || "${enabled}" == "yes" ]]; then
    mount_path="${RCLONE_MOUNT_PATH:-/data/gdrive}"
    for _ in $(seq 1 30); do
        if mountpoint -q "${mount_path}"; then
            break
        fi
        sleep 1
    done

    if ! mountpoint -q "${mount_path}"; then
        echo "rclone mount was enabled but ${mount_path} is not mounted" >&2
        exit 1
    fi
fi

cd /app

exec s6-setuidgid abc \
    java \
    -Dspring.profiles.include=docker \
    --enable-native-access=ALL-UNNAMED \
    -jar application.jar \
    --spring.config.additional-location="file:${KOMGA_CONFIGDIR:-/config}/"
